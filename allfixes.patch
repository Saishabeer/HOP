From 8e51ad8f9fa37df7d5d7e4758fe4accb36d5f82c Mon Sep 17 00:00:00 2001
From: Claude <noreply@anthropic.com>
Date: Wed, 24 Jun 2026 17:51:40 +0000
Subject: [PATCH 2/3] Fix three UI bugs: filter drawer alignment typo, footer
 text color, hero horizontal overflow
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

- shop.css: Fix typo `align-center` → `align-items` in .filter-drawer__header so the mobile filter drawer title and close button align vertically
- footer.css: Add `.footer p { color: inherit }` so paragraph text inside the dark footer background inherits cream color instead of charcoal from the global p rule
- global.css: Add `overflow-x: hidden` to body to prevent horizontal scrollbar caused by the hero section's 100vw width on Windows (where scrollbars take layout space)

Co-Authored-By: Claude Sonnet 4.6 <noreply@anthropic.com>
Claude-Session: https://claude.ai/code/session_01M1quBftFn1gphS2uC1gqWJ
---
 css/footer.css | 4 ++++
 css/global.css | 1 +
 css/shop.css   | 2 +-
 3 files changed, 6 insertions(+), 1 deletion(-)

diff --git a/css/footer.css b/css/footer.css
index 2993df3..54ae041 100644
--- a/css/footer.css
+++ b/css/footer.css
@@ -82,6 +82,10 @@
   opacity: 1;
 }
 
+.footer p {
+  color: inherit;
+}
+
 .footer__contact-info {
   display: flex;
   flex-direction: column;
diff --git a/css/global.css b/css/global.css
index 7a4c325..b35e912 100644
--- a/css/global.css
+++ b/css/global.css
@@ -9,6 +9,7 @@ body {
   display: flex;
   flex-direction: column;
   min-height: 100vh;
+  overflow-x: hidden;
 }
 
 main {
diff --git a/css/shop.css b/css/shop.css
index db42d5d..f274b2e 100644
--- a/css/shop.css
+++ b/css/shop.css
@@ -254,7 +254,7 @@
   border-bottom: 1px solid var(--velvet-cream);
   display: flex;
   justify-content: space-between;
-  align-center: center;
+  align-items: center;
 }
 
 .filter-drawer__title {
